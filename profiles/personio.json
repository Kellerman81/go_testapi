{
  "_comment": "Maps Personio HR API endpoints to go_testapi's internal person/contract store.",

  "name": "personio",
  "routes": [
    {
      "method": "POST",
      "path":   "/v1/auth",
      "action": "issue_token",
      "token_field": "data.token",
      "body": { "success": true, "data": {} }
    },

    {
      "method": "GET",
      "path":   "/v1/company/employees",
      "action": "list_persons",
      "limiter": "person",
      "output": {
        "merge_first_contract": "contract",
        "list_key":   "data",
        "list_extra": { "success": true, "offset": 0, "limit": 200, "metadata": { "current_page": 0, "total_pages": 1 } },
        "item_key":   "attributes",
        "item_extra": { "type": "Employee" },
        "attribute_style": "labeled",
        "field_map": {
          "id":                     "id",
          "first_name":             "first_name",
          "last_name":              "last_name",
          "email":                  "email",
          "birthday":               "birthday",
          "address.street":         "street",
          "address.city":           "city",
          "address.state":          "state",
          "address.zip":            "zip",
          "address.country":        "country",
          "contract.start_date":    "hire_date",
          "contract.end_date":      "contract_end_date",
          "contract.department":    "department",
          "contract.title":         "position",
          "contract.manager":       "supervisor",
          "contract.company":       "company"
        },
        "field_formats": {
          "hire_date":           "yyyy-MM-dd'T'HH:mm:ssZ",
          "contract_end_date":   "yyyy-MM-dd'T'HH:mm:ssZ"
        },
        "value_objects": {
          "department": { "type": "Department", "attributes": { "id": 0, "name": "$" } },
          "supervisor": { "type": "Employee", "attributes": { "id": { "label": "ID", "value": "$", "type": "integer", "universal_id": "id" } } }
        }
      }
    },
    {
      "method": "GET",
      "path":   "/v1/company/employees/:id",
      "action": "get_person",
      "limiter": "person",
      "output": {
        "merge_first_contract": "contract",
        "item_key":   "attributes",
        "item_extra": { "type": "Employee" },
        "attribute_style": "labeled",
        "field_map": {
          "id":                     "id",
          "first_name":             "first_name",
          "last_name":              "last_name",
          "email":                  "email",
          "birthday":               "birthday",
          "address.street":         "street",
          "address.city":           "city",
          "address.state":          "state",
          "address.zip":            "zip",
          "address.country":        "country",
          "contract.start_date":    "hire_date",
          "contract.end_date":      "contract_end_date",
          "contract.department":    "department",
          "contract.title":         "position",
          "contract.manager":       "supervisor",
          "contract.company":       "company"
        },
        "field_formats": {
          "hire_date":           "yyyy-MM-dd'T'HH:mm:ssZ",
          "contract_end_date":   "yyyy-MM-dd'T'HH:mm:ssZ"
        },
        "value_objects": {
          "department": { "type": "Department", "attributes": { "id": 0, "name": "$" } },
          "supervisor": { "type": "Employee", "attributes": { "id": { "label": "ID", "value": "$", "type": "integer", "universal_id": "id" } } }
        }
      }
    },
    {
      "method": "POST",
      "path":   "/v1/company/employees",
      "action": "create_person",
      "limiter": "person",
      "input": {
        "item_key": "attributes",
        "attribute_style": "labeled",
        "field_map": {
          "first_name":      "first_name",
          "last_name":       "last_name",
          "email":           "email",
          "birthday":        "birthday",
          "address.street":  "street",
          "address.city":    "city",
          "address.state":   "state",
          "address.zip":     "zip",
          "address.country": "country",
          "department":      "department",
          "position":        "position",
          "supervisor":      "supervisor"
        },
        "value_paths": {
          "department": "attributes.name",
          "supervisor": "attributes.id.value"
        }
      },
      "output": {
        "merge_first_contract": "contract",
        "item_key":   "attributes",
        "item_extra": { "type": "Employee" },
        "attribute_style": "labeled",
        "field_map": {
          "id":                     "id",
          "first_name":             "first_name",
          "last_name":              "last_name",
          "email":                  "email",
          "birthday":               "birthday",
          "address.street":         "street",
          "address.city":           "city",
          "address.state":          "state",
          "address.zip":            "zip",
          "address.country":        "country",
          "contract.start_date":    "hire_date",
          "contract.end_date":      "contract_end_date",
          "contract.department":    "department",
          "contract.title":         "position",
          "contract.manager":       "supervisor",
          "contract.company":       "company"
        },
        "field_formats": {
          "hire_date":           "yyyy-MM-dd'T'HH:mm:ssZ",
          "contract_end_date":   "yyyy-MM-dd'T'HH:mm:ssZ"
        },
        "value_objects": {
          "department": { "type": "Department", "attributes": { "id": 0, "name": "$" } },
          "supervisor": { "type": "Employee", "attributes": { "id": { "label": "ID", "value": "$", "type": "integer", "universal_id": "id" } } }
        }
      }
    },
    {
      "method": "PUT",
      "path":   "/v1/company/employees/:id",
      "action": "update_person",
      "limiter": "person",
      "input": {
        "item_key": "attributes",
        "attribute_style": "labeled",
        "field_map": {
          "first_name":      "first_name",
          "last_name":       "last_name",
          "email":           "email",
          "birthday":        "birthday",
          "address.street":  "street",
          "address.city":    "city",
          "address.state":   "state",
          "address.zip":     "zip",
          "address.country": "country",
          "department":      "department",
          "position":        "position",
          "supervisor":      "supervisor"
        },
        "value_paths": {
          "department": "attributes.name",
          "supervisor": "attributes.id.value"
        }
      },
      "output": {
        "merge_first_contract": "contract",
        "item_key":   "attributes",
        "item_extra": { "type": "Employee" },
        "attribute_style": "labeled",
        "field_map": {
          "id":                     "id",
          "first_name":             "first_name",
          "last_name":              "last_name",
          "email":                  "email",
          "birthday":               "birthday",
          "address.street":         "street",
          "address.city":           "city",
          "address.state":          "state",
          "address.zip":            "zip",
          "address.country":        "country",
          "contract.start_date":    "hire_date",
          "contract.end_date":      "contract_end_date",
          "contract.department":    "department",
          "contract.title":         "position",
          "contract.manager":       "supervisor",
          "contract.company":       "company"
        },
        "field_formats": {
          "hire_date":           "yyyy-MM-dd'T'HH:mm:ssZ",
          "contract_end_date":   "yyyy-MM-dd'T'HH:mm:ssZ"
        },
        "value_objects": {
          "department": { "type": "Department", "attributes": { "id": 0, "name": "$" } },
          "supervisor": { "type": "Employee", "attributes": { "id": { "label": "ID", "value": "$", "type": "integer", "universal_id": "id" } } }
        }
      }
    },
    {
      "method": "DELETE",
      "path":   "/v1/company/employees/:id",
      "action": "delete_person",
      "limiter": "person"
    },

    {
      "method": "GET",
      "path":   "/v1/company/employees/:id/contracts",
      "action": "list_contracts",
      "limiter": "person",
      "output": {
        "list_key":   "data",
        "list_extra": { "success": true, "offset": 0, "limit": 200, "metadata": { "current_page": 0, "total_pages": 1 } },
        "item_key":   "attributes",
        "item_extra": { "type": "Contract" },
        "attribute_style": "labeled",
        "field_map": {
          "id":         "id",
          "person_id":  "employee_id",
          "company":    "company",
          "title":      "position",
          "department": "department",
          "manager":    "supervisor",
          "start_date": "start_date",
          "end_date":   "end_date"
        },
        "field_formats": {
          "start_date": "yyyy-MM-dd'T'HH:mm:ssZ",
          "end_date":   "yyyy-MM-dd'T'HH:mm:ssZ"
        },
        "value_objects": {
          "department": { "type": "Department", "attributes": { "id": 0, "name": "$" } },
          "supervisor": { "type": "Employee", "attributes": { "id": { "label": "ID", "value": "$", "type": "integer", "universal_id": "id" } } }
        }
      }
    },
    {
      "method": "GET",
      "path":   "/v1/company/employees/:id/contracts/:contractId",
      "action": "get_contract",
      "limiter": "person",
      "output": {
        "item_key":   "attributes",
        "item_extra": { "type": "Contract" },
        "attribute_style": "labeled",
        "field_map": {
          "id":         "id",
          "person_id":  "employee_id",
          "company":    "company",
          "title":      "position",
          "department": "department",
          "manager":    "supervisor",
          "start_date": "start_date",
          "end_date":   "end_date"
        },
        "field_formats": {
          "start_date": "yyyy-MM-dd'T'HH:mm:ssZ",
          "end_date":   "yyyy-MM-dd'T'HH:mm:ssZ"
        },
        "value_objects": {
          "department": { "type": "Department", "attributes": { "id": 0, "name": "$" } },
          "supervisor": { "type": "Employee", "attributes": { "id": { "label": "ID", "value": "$", "type": "integer", "universal_id": "id" } } }
        }
      }
    }
  ]
}
