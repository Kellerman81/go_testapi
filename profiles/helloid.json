{
  "_comment": [
    "Maps HelloID (Tools4ever) REST API endpoints to go_testapi's internal store.",
    "Set your connector's base URL to http://<host> and leave all script logic unchanged.",
    "",
    "Auth:  Basic base64(client_id:secret)",
    "Base:  http://<host>",
    "",
    "lookup_field on get_user allows initial correlation by userName before the GUID is known.",
    "take_param / skip_param support the connector's paging parameters."
  ],

  "name": "helloid",
  "routes": [
    {
      "method": "GET",
      "path":   "/users",
      "action": "list_users",
      "output": {
        "raw": true,
        "field_map": {
          "id":         "userGUID",
          "username":   "userName",
          "enabled":    "isEnabled",
          "email":      "emailAddress",
          "first_name": "firstName",
          "last_name":  "lastName"
        }
      }
    },
    {
      "method": "GET",
      "path":        "/users/:id",
      "action":      "get_user",
      "lookup_field": "username",
      "output": {
        "item_extra": { "userAttributes": {}, "managedByUserGUID": null },
        "field_map": {
          "id":         "userGUID",
          "username":   "userName",
          "enabled":    "isEnabled",
          "email":      "emailAddress",
          "first_name": "firstName",
          "last_name":  "lastName"
        }
      }
    },
    {
      "method": "POST",
      "path":   "/users",
      "action": "create_user",
      "input": {
        "field_map": {
          "id":         "userGUID",
          "username":   "userName",
          "enabled":    "isEnabled",
          "email":      "emailAddress",
          "first_name": "firstName",
          "last_name":  "lastName"
        }
      },
      "output": {
        "item_extra": { "userAttributes": {}, "managedByUserGUID": null },
        "field_map": {
          "id":         "userGUID",
          "username":   "userName",
          "enabled":    "isEnabled",
          "email":      "emailAddress",
          "first_name": "firstName",
          "last_name":  "lastName"
        }
      }
    },
    {
      "method": "PUT",
      "path":   "/users/:id",
      "action": "update_user",
      "input": {
        "field_map": {
          "id":         "userGUID",
          "username":   "userName",
          "enabled":    "isEnabled",
          "email":      "emailAddress",
          "first_name": "firstName",
          "last_name":  "lastName"
        }
      },
      "output": {
        "item_extra": { "userAttributes": {}, "managedByUserGUID": null },
        "field_map": {
          "id":         "userGUID",
          "username":   "userName",
          "enabled":    "isEnabled",
          "email":      "emailAddress",
          "first_name": "firstName",
          "last_name":  "lastName"
        }
      }
    },
    {
      "method": "DELETE",
      "path":   "/users/:id",
      "action": "delete_user"
    },

    {
      "method": "GET",
      "path":   "/groups",
      "action": "list_groups",
      "output": {
        "raw":        true,
        "id_field":   "groupGuid",
        "name_field": "name"
      }
    },
    {
      "method": "POST",
      "path":            "/users/:id/groups",
      "action":          "link_group",
      "user_body_field": "groupGuid",
      "status":          200
    },
    {
      "method": "DELETE",
      "path":   "/users/:id/groups/:groupId",
      "action": "unlink_group",
      "status": 200
    },

    {
      "method": "GET",
      "path":   "/products",
      "action": "static",
      "body": [
        { "productId": "product-001", "name": "Product A", "description": "Sample product A" },
        { "productId": "product-002", "name": "Product B", "description": "Sample product B" }
      ]
    },
    {
      "method": "GET",
      "path":   "/product-assignment/by-user/:id",
      "action": "static",
      "body":   []
    },
    {
      "method": "POST",
      "path":   "/selfservice/products/request",
      "action": "static",
      "body":   { "success": true }
    },
    {
      "method": "POST",
      "path":   "/product-assignment/unassign/by-product",
      "action": "static",
      "body":   { "success": true }
    }
  ]
}
